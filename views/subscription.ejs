async function buy(plan) {

  try {
    const user = JSON.parse(localStorage.getItem("user"));
    const username = user?.username;

    if (!username) {
      showPopup("⚠️ Please login first", "#e74c3c");
      return;
    }

    let res = await fetch(
      "https://food-health-classifier1.onrender.com/create-order?plan=" 
      + plan + "&username=" + username
    );

    let order = await res.json();

    let options = {
      key: "rzp_test_S7himHMdfujbzL",
      amount: order.amount,
      order_id: order.id,

      handler: async function (response) {

        await fetch(
          "https://food-health-classifier1.onrender.com/verify-payment",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              razorpay_order_id: response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature: response.razorpay_signature,
              username: username,
              plan: plan
            })
          }
        );

        showPopup("✅ Payment Successful!");

        setTimeout(() => {
          window.location.href = "/scan";
        }, 1500);
      }
    };

    new Razorpay(options).open();

  } catch (err) {
    console.error(err);
    showPopup("❌ Payment Failed", "#e74c3c");
  }
}


