<script>
/* =========================
   ✅ SCAN LIMIT LOGIC (YOUR CODE)
========================= */
let scansLeft = localStorage.getItem("scansLeft");

if (scansLeft === null) {
    scansLeft = 5;
    localStorage.setItem("scansLeft", scansLeft);
} else {
    scansLeft = parseInt(scansLeft);
}

function showUpgrade() {
    alert("⚠ Free trial ended! Redirecting to upgrade page...");
    setTimeout(() => {
        window.location.href = "/subscription";
    }, 1000);
}

/* =========================
   ✅ CAMERA / GALLERY (MERGED)
========================= */
function openCamera() {
    if (scansLeft <= 0) return showUpgrade(); // 🔥 added

    const input = document.getElementById("cameraInput");
    input.click();
    input.onchange = handleImage;
}

function openGallery() {
    if (scansLeft <= 0) return showUpgrade(); // 🔥 added

    const input = document.getElementById("galleryInput");
    input.click();
    input.onchange = handleImage;
}

/* =========================
   ✅ MAIN IMAGE HANDLER (MERGED)
========================= */
async function handleImage(event) {

    // 🔥 LIMIT CHECK (YOUR CODE)
    if (scansLeft <= 0) {
        showUpgrade();
        return;
    }

    const file = event.target.files[0];
    event.target.value = "";
    if (!file) return;

    document.getElementById("loadingOverlay").style.display = "flex";

    try {
        const img = new Image();
        img.src = URL.createObjectURL(file);

        await new Promise(resolve => img.onload = resolve);

        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');

        const maxWidth = 800;
        const scale = Math.min(maxWidth / img.width, 1);

        canvas.width = img.width * scale;
        canvas.height = img.height * scale;

        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const data = imageData.data;

        for (let i = 0; i < data.length; i += 4) {
            const avg = (data[i] + data[i + 1] + data[i + 2]) / 3;
            const val = avg > 150 ? 255 : 0;
            data[i] = data[i + 1] = data[i + 2] = val;
        }

        ctx.putImageData(imageData, 0, 0);

        const { data: { text } } = await Tesseract.recognize(canvas, 'eng', {
            tessedit_char_whitelist: '0123456789.caloriesproteinfatcarbsfibersodiumsugar',
            logger: m => console.log(m)
        });

        console.log("OCR TEXT:", text);

        const parsed = parseNutrition(text);

        /* 🔥 DECREASE SCAN COUNT (YOUR CODE) */
        scansLeft--;
        localStorage.setItem("scansLeft", scansLeft);

        /* 🔔 WARNINGS */
        if (scansLeft === 2) alert("⚠ Only 2 scans left!");
        if (scansLeft === 1) alert("🚨 Last scan remaining!");

        /* ❌ BLOCK AFTER LIMIT */
        if (scansLeft <= 0) {
            document.getElementById("loadingOverlay").style.display = "none";
            showUpgrade();
            return;
        }

        document.getElementById("loadingOverlay").style.display = "none";

        const query = new URLSearchParams(parsed).toString();
        window.location.href = "/form?" + query;

    } catch (err) {
        console.error(err);
        alert("Scan failed. Try again.");
        document.getElementById("loadingOverlay").style.display = "none";
    }
}

