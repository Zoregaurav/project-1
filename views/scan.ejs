<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scan Product</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Lato:wght@300;400;700&display=swap"
        rel="stylesheet" />
    <style>
        /* ═══════════════════════════════════════════════
       TOKENS & RESET
    ═══════════════════════════════════════════════ */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --teal: #0f766e;
            --teal-lt: #14b8a6;
            --green: #22c55e;
            --green-dk: #16a34a;
            --bg: #f8fafc;
            --bg2: #f1f5f9;
            --surface: #ffffff;
            --border: #e2e8f0;
            --text: #0f172a;
            --muted: #64748b;
            --muted-lt: #94a3b8;
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: var(--bg);
            font-family: 'Lato', sans-serif;
            color: var(--text);
            overflow-x: hidden;
        }

        /* ═══════════════════════════════════════════════
       NAVBAR
    ═══════════════════════════════════════════════ */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 18px 0;
            transition: all 0.35s ease;
            background: transparent;
        }

        .navbar.scrolled {
            background: rgba(255, 255, 255, 0.82);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border);
            padding: 12px 0;
            box-shadow: 0 4px 24px rgba(15, 118, 110, 0.08);
        }

        .navbar-brand {
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            font-size: 1.35rem;
            color: var(--teal) !important;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .brand-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--green);
            display: inline-block;
            animation: pulse-dot 2s ease-in-out infinite;
        }

        @keyframes pulse-dot {

            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
            }

            50% {
                box-shadow: 0 0 0 6px rgba(34, 197, 94, 0);
            }
        }

        .nav-link {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text) !important;
            padding: 6px 4px !important;
            margin: 0 12px;
            position: relative;
            transition: color 0.25s;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--teal-lt);
            border-radius: 2px;
            transition: width 0.3s ease;
        }

        .nav-link:hover {
            color: var(--teal) !important;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .btn-nav-cta {
            background: var(--teal);
            color: #fff !important;
            border-radius: 50px;
            padding: 9px 22px !important;
            font-size: 0.875rem !important;
            font-weight: 600 !important;
            margin-left: 8px !important;
            transition: all 0.3s ease;
            box-shadow: 0 0 0 0 rgba(15, 118, 110, 0.4);
        }

        .navbar-toggler {
            border: 1.5px solid rgba(15, 118, 110, 0.3) !important;
            border-radius: 8px;
            padding: 6px 10px;
        }

        .navbar-toggler:focus {
            box-shadow: none;
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%230f766e' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
        }

        .btn-nav-cta::after {
            display: none;
        }

        .btn-nav-cta:hover {
            background: var(--teal-lt);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(15, 118, 110, 0.35);
        }

        /* ═══════════════════════════════════════════════
       HERO
    ═══════════════════════════════════════════════ */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
            background: var(--bg);
        }

        /* Background blobs */
        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.35;
            pointer-events: none;
        }

        .blob-1 {
            width: 520px;
            height: 520px;
            background: radial-gradient(circle, #99f6e4, #0d9488);
            top: -120px;
            right: -80px;
            animation: drift1 14s ease-in-out infinite;
        }

        .blob-2 {
            width: 360px;
            height: 360px;
            background: radial-gradient(circle, #bbf7d0, #22c55e);
            bottom: 0;
            left: -100px;
            animation: drift2 18s ease-in-out infinite;
        }

        .blob-3 {
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, #e0f2fe, #38bdf8);
            top: 40%;
            left: 42%;
            animation: drift3 12s ease-in-out infinite;
        }

        @keyframes drift1 {

            0%,
            100% {
                transform: translate(0, 0) scale(1);
            }

            50% {
                transform: translate(30px, 40px) scale(1.05);
            }
        }

        @keyframes drift2 {

            0%,
            100% {
                transform: translate(0, 0) scale(1);
            }

            50% {
                transform: translate(-20px, -30px) scale(1.08);
            }
        }

        @keyframes drift3 {

            0%,
            100% {
                transform: translate(0, 0);
            }

            50% {
                transform: translate(20px, -20px);
            }
        }

        /* Pill badge */
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(20, 184, 166, 0.1);
            border: 1px solid rgba(20, 184, 166, 0.3);
            color: var(--teal);
            font-size: 0.78rem;
            font-weight: 600;
            padding: 6px 14px;
            border-radius: 50px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            margin-bottom: 24px;
            opacity: 0;
            animation: slideUp 0.7s ease forwards 0.2s;
        }

        .badge-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--green);
        }

        /* Hero text */
        .hero-title {
            font-family: 'Nunito', sans-serif;
            font-size: clamp(2rem, 3.2vw, 3rem);
            font-weight: 900;
            line-height: 1.18;
            letter-spacing: -0.5px;
            color: var(--text);
            opacity: 0;
            animation: slideUp 0.75s ease forwards 0.35s;
        }

        .hero-title .highlight {
            background: linear-gradient(135deg, var(--teal), var(--teal-lt), var(--green));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-sub {
            font-size: 1.05rem;
            color: var(--muted);
            line-height: 1.75;
            max-width: 480px;
            margin-top: 18px;
            font-weight: 400;
            opacity: 0;
            animation: slideUp 0.75s ease forwards 0.5s;
        }

        .hero-actions {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-top: 36px;
            flex-wrap: wrap;
            opacity: 0;
            animation: slideUp 0.75s ease forwards 0.65s;
        }

        .btn-primary-cta {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--teal);
            color: #fff;
            border: none;
            border-radius: 50px;
            padding: 14px 30px;
            font-family: 'Lato', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(15, 118, 110, 0.3);
        }

        .btn-primary-cta:hover {
            background: #0d6b63;
            transform: translateY(-3px);
            box-shadow: 0 10px 32px rgba(15, 118, 110, 0.45);
            color: #fff;
        }

        .btn-primary-cta .arrow {
            transition: transform 0.25s ease;
        }

        .btn-primary-cta:hover .arrow {
            transform: translateX(4px);
        }

        .btn-outline-cta {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: transparent;
            color: var(--text);
            border: 1.5px solid var(--border);
            border-radius: 50px;
            padding: 13px 26px;
            font-family: 'Lato', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-outline-cta:hover {
            border-color: var(--teal-lt);
            color: var(--teal);
            background: rgba(20, 184, 166, 0.05);
            transform: translateY(-2px);
        }

        /* Trust row */
        .trust-row {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: 48px;
            opacity: 0;
            animation: slideUp 0.75s ease forwards 0.8s;
        }

        .trust-divider {
            width: 1px;
            height: 28px;
            background: var(--border);
        }

        .trust-item {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .trust-number {
            font-family: 'Nunito', sans-serif;
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--teal);
        }

        .trust-label {
            font-size: 0.73rem;
            color: var(--muted-lt);
            font-weight: 500;
            letter-spacing: 0.3px;
        }

        /* Hero image panel */
        .hero-visual {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            animation: fadeIn 1s ease forwards 0.5s;
        }

        .hero-img-wrap {
            position: relative;
            width: 100%;
            max-width: 440px;
        }

        .hero-img-bg {
            position: absolute;
            inset: -20px;
            background: radial-gradient(ellipse at center, rgba(20, 184, 166, 0.15) 0%, transparent 70%);
            border-radius: 50%;
        }

        .hero-img {
            width: 100%;
            height: auto;
            border-radius: var(--radius-lg);
            position: relative;
            z-index: 1;
            animation: float 5s ease-in-out infinite;
            filter: drop-shadow(0 24px 48px rgba(15, 118, 110, 0.2));
        }

        /* Floating cards on hero image */
        .float-card {
            position: absolute;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.82rem;
            font-weight: 600;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            z-index: 2;
            white-space: nowrap;
        }

        .float-card-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

        .float-card-1 {
            top: 10%;
            left: -60px;
            animation: float 6s ease-in-out infinite 0.5s;
        }

        .float-card-2 {
            bottom: 15%;
            right: -50px;
            animation: float 5.5s ease-in-out infinite 1s;
        }

        .fc-green {
            background: rgba(34, 197, 94, 0.12);
        }

        .fc-teal {
            background: rgba(20, 184, 166, 0.12);
        }

        .float-text {
            color: var(--text);
        }

        .float-sub {
            font-size: 0.7rem;
            color: var(--muted);
            font-weight: 400;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-12px);
            }
        }

        /* ═══════════════════════════════════════════════
       SECTION SHARED
    ═══════════════════════════════════════════════ */
        .section-eyebrow {
            font-size: 0.75rem;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--teal);
            margin-bottom: 12px;
        }

        .section-title {
            font-family: 'Nunito', sans-serif;
            font-size: clamp(1.6rem, 2.4vw, 2.2rem);
            font-weight: 800;
            letter-spacing: -0.3px;
            line-height: 1.25;
            color: var(--text);
        }

        .section-sub {
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.7;
            max-width: 520px;
            margin: 0 auto;
        }

        /* ═══════════════════════════════════════════════
       INFO / CARDS SECTION
    ═══════════════════════════════════════════════ */
        .info-section {
            padding: 100px 0;
            background: var(--bg);
        }

        .info-header {
            text-align: center;
            margin-bottom: 64px;
        }

        /* Feature card */
        .feat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 36px 32px;
            height: 100%;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            opacity: 0;
            transform: translateY(32px);
        }

        .feat-card.visible {
            opacity: 1;
            transform: translateY(0);
            transition: opacity 0.55s ease, transform 0.55s ease;
        }

        .feat-card:hover {
            border-color: rgba(20, 184, 166, 0.4);
            box-shadow: 0 20px 56px rgba(15, 118, 110, 0.12);
            transform: translateY(-6px) !important;
        }

        /* Hover shimmer line */
        .feat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--teal), var(--green));
            opacity: 0;
            transition: opacity 0.3s ease;
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        }

        .feat-card:hover::before {
            opacity: 1;
        }

        .feat-icon-wrap {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            margin-bottom: 22px;
        }

        .ic-teal {
            background: rgba(20, 184, 166, 0.1);
        }

        .ic-green {
            background: rgba(34, 197, 94, 0.1);
        }

        .ic-blue {
            background: rgba(56, 189, 248, 0.1);
        }

        .feat-title {
            font-family: 'Nunito', sans-serif;
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 10px;
        }

        .feat-text {
            font-size: 0.9rem;
            color: var(--muted);
            line-height: 1.7;
        }

        .feat-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--teal);
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            margin-top: 20px;
            transition: gap 0.25s ease;
        }

        .feat-link:hover {
            gap: 10px;
            color: var(--teal-lt);
        }

        /* ═══════════════════════════════════════════════
       HOW IT WORKS
    ═══════════════════════════════════════════════ */
        .how-section {
            padding: 100px 0;
            background: var(--bg2);
        }

        .steps-wrap {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2px;
            position: relative;
            margin-top: 60px;
        }

        .steps-wrap::before {
            content: '';
            position: absolute;
            top: 28px;
            left: calc(16.6% + 28px);
            right: calc(16.6% + 28px);
            height: 1px;
            background: linear-gradient(90deg, var(--teal), var(--green));
            opacity: 0.3;
        }

        .step-item {
            text-align: center;
            padding: 0 24px;
            opacity: 0;
            transform: translateY(24px);
        }

        .step-item.visible {
            opacity: 1;
            transform: translateY(0);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }

        .step-num {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: var(--surface);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-family: 'Nunito', sans-serif;
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--teal);
            position: relative;
            z-index: 1;
            transition: all 0.3s ease;
        }

        .step-item:hover .step-num {
            background: var(--teal);
            color: #fff;
            border-color: var(--teal);
            box-shadow: 0 0 0 6px rgba(15, 118, 110, 0.15);
        }

        .step-title {
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 8px;
            color: var(--text);
        }

        .step-desc {
            font-size: 0.87rem;
            color: var(--muted);
            line-height: 1.65;
        }

        /* ═══════════════════════════════════════════════
       CTA BANNER WITH SCANNING ANIMATION
    ═══════════════════════════════════════════════ */
        .cta-section {
            padding: 80px 0;
            background: var(--bg);
        }

        .cta-inner {
            background: linear-gradient(135deg, var(--teal) 0%, #0d9488 50%, #0f766e 100%);
            border-radius: var(--radius-lg);
            padding: 64px 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 40px;
            position: relative;
            overflow: hidden;
        }

        .cta-inner::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.07);
            border-radius: 50%;
        }

        .cta-inner::after {
            content: '';
            position: absolute;
            bottom: -80px;
            left: 30%;
            width: 220px;
            height: 220px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
        }

        /* Scanning waves animation */
        .scan-waves {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }

        .wave-line {
            position: absolute;
            left: -100%;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg,
                    transparent 0%,
                    rgba(255, 255, 255, 0.4) 20%,
                    rgba(255, 255, 255, 0.8) 50%,
                    rgba(255, 255, 255, 0.4) 80%,
                    transparent 100%);
            animation: scanWave 4s linear infinite;
            filter: blur(1px);
        }

        .wave-line:nth-child(1) {
            top: 25%;
            animation-delay: 0s;
        }

        .wave-line:nth-child(2) {
            top: 50%;
            animation-delay: 1.3s;
            opacity: 0.7;
        }

        .wave-line:nth-child(3) {
            top: 75%;
            animation-delay: 2.6s;
            opacity: 0.5;
        }

        @keyframes scanWave {
            0% {
                left: -100%;
                opacity: 0;
            }

            10% {
                opacity: 1;
            }

            90% {
                opacity: 1;
            }

            100% {
                left: 100%;
                opacity: 0;
            }
        }

        /* Floating scan particles */
        .scan-particles {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(255, 255, 255, 0.6);
            border-radius: 50%;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
        }

        .particle:nth-child(1) {
            top: 20%;
            left: 10%;
            animation: floatParticle 6s ease-in-out infinite;
        }

        .particle:nth-child(2) {
            top: 60%;
            left: 30%;
            animation: floatParticle 7s ease-in-out infinite 1s;
        }

        .particle:nth-child(3) {
            top: 40%;
            left: 70%;
            animation: floatParticle 8s ease-in-out infinite 2s;
        }

        .particle:nth-child(4) {
            top: 80%;
            left: 50%;
            animation: floatParticle 6.5s ease-in-out infinite 1.5s;
        }

        .particle:nth-child(5) {
            top: 30%;
            left: 85%;
            animation: floatParticle 7.5s ease-in-out infinite 0.5s;
        }

        @keyframes floatParticle {

            0%,
            100% {
                transform: translate(0, 0) scale(1);
                opacity: 0;
            }

            10% {
                opacity: 1;
            }

            50% {
                transform: translate(30px, -20px) scale(1.2);
                opacity: 0.8;
            }

            90% {
                opacity: 1;
            }
        }

        /* Wavy gradient overlay */
        .wave-gradient {
            position: absolute;
            inset: 0;
            background: linear-gradient(45deg,
                    rgba(255, 255, 255, 0) 0%,
                    rgba(255, 255, 255, 0.05) 50%,
                    rgba(255, 255, 255, 0) 100%);
            background-size: 200% 200%;
            animation: waveGradient 8s ease-in-out infinite;
            pointer-events: none;
            z-index: 0;
        }

        @keyframes waveGradient {

            0%,
            100% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }
        }

        /* Pulsing glow effect */
        .pulse-glow {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            animation: pulseGlow 3s ease-in-out infinite;
            pointer-events: none;
            z-index: 0;
        }

        @keyframes pulseGlow {

            0%,
            100% {
                transform: translate(-50%, -50%) scale(1);
                opacity: 0.3;
            }

            50% {
                transform: translate(-50%, -50%) scale(1.2);
