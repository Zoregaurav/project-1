/* =========================
   ✅ PARSER (UNCHANGED TEAM CODE)
========================= */
function parseNutrition(text) {
    const lower = text.toLowerCase();

    const extract = (regex) => {
        const match = lower.match(regex);
        if (!match) return 0;

        let val = match[1];

        val = val.replace(/o/g, '0');
        val = val.replace(/g/g, '9');
        val = val.replace(/l/g, '1');

        return parseFloat(val) || 0;
    };

    return {
        Calories: extract(/(?:calories|energy)\s*(\d+\.?\d*)/),
        Protein: extract(/protein\s*(\d+\.?\d*)/),
        Carbohydrates: extract(/(?:carbs|carbohydrates?)\s*(\d+\.?\d*)/),
        Fat: extract(/(?:total fat|fat)\s*(\d+\.?\d*)/),
        Fiber: extract(/(?:fiber|fibre)\s*(\d+\.?\d*)/),
        Sugars: extract(/(?:sugar|sugars)\s*(\d+\.?\d*)/),
        Sodium: extract(/sodium\s*(\d+\.?\d*)/),
        Cholesterol: extract(/cholesterol\s*(\d+\.?\d*)/)
    };
}

/* =========================
   ✅ TEAM FEATURE (UNLABELED SCAN KEPT)
========================= */
function openUnlabeled() {
    if (scansLeft <= 0) return showUpgrade(); // 🔥 added

    const input = document.getElementById("unlabeledInput");
    input.click();
    input.onchange = handleUnlabeled;
}

async function handleUnlabeled(event) {

    if (scansLeft <= 0) {
        showUpgrade();
        return;
    }

    const file = event.target.files[0];
    if (!file) return;

    document.getElementById("loadingOverlay").style.display = "flex";

    const formData = new FormData();
    formData.append("image", file);

    try {
        const res = await fetch("/unlabeled-scan", {
            method: "POST",
            body: formData
        });

        const data = await res.json();

        /* 🔥 DECREASE SCAN COUNT */
        scansLeft--;
        localStorage.setItem("scansLeft", scansLeft);

        document.getElementById("loadingOverlay").style.display = "none";

        const query = new URLSearchParams(data.macros).toString();
        window.location.href = "/form?" + query;

    } catch (err) {
        console.error(err);
        document.getElementById("loadingOverlay").style.display = "none";
        alert("Unlabeled scan failed");
    }

}
